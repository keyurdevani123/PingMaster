# These values go into Cloudflare dashboard → Worker → Settings → Variables
# DO NOT commit real values — this file is just a reference

UPSTASH_REDIS_REST_URL="your_upstash_redis_url_here"
UPSTASH_REDIS_REST_TOKEN="your_upstash_redis_token_here"
RESEND_API_KEY="your_resend_api_key_here"
FRONTEND_APP_URL="http://localhost:5173"
FIREBASE_PROJECT_ID="your_firebase_project_id_here"
GEMINI_API_KEY="your_gemini_api_key_here"
GEMINI_MODEL="gemini-2.5-flash"
RAZORPAY_KEY_ID="your_razorpay_key_id_here"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret_here"
RAZORPAY_WEBHOOK_SECRET="your_razorpay_webhook_secret_here"
# Subscription checkout requires recurring plan ids for each paid tier.
RAZORPAY_PLAN_ID_PLUS="plan_xxxxx"
RAZORPAY_PLAN_ID_PRO="plan_xxxxx"
# Optional display/reference amounts. The recurring charge comes from the Razorpay plan itself.
RAZORPAY_PLUS_AMOUNT_PAISA="24900"
RAZORPAY_PRO_AMOUNT_PAISA="79900"
